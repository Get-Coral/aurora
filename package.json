{
  "name": "aurora-ui",
  "private": false,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "node server.mjs",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "cap:sync": "pnpm build && cap sync",
    "cap:copy": "pnpm build && cap copy",
    "android:assemble:debug": "cd android && ./gradlew assembleDebug",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "cap:run:android": "export JAVA_HOME=\"$([ -d /opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home ] && printf %s /opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home || /usr/libexec/java_home -v 21 2>/dev/null || /usr/libexec/java_home -v 17 2>/dev/null || /usr/libexec/java_home)\" && export PATH=\"$JAVA_HOME/bin:$PATH\" && pnpm build && cap run android",
    "cap:run:ios": "pnpm build && node scripts/run-capacitor-ios.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@get-coral/jellyfin": "^1.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "lucide-react": "^0.577.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@get-coral/biome-config": "^0.2.0",
    "@get-coral/tsconfig": "^0.2.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "version": "1.5.0"
}
