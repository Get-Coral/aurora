# Jellyfin (optional in local dev, not required once you use the in-app setup flow)
JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=your_api_key_here
JELLYFIN_USER_ID=your_user_id_here
JELLYFIN_USERNAME=your_username_here
JELLYFIN_PASSWORD=your_password_here

# Require everyone to sign in with their Jellyfin username & password before
# they can browse or stream. Strongly recommended when Aurora is exposed to
# the internet. Can also be toggled in Settings; setting it here locks it on.
# AURORA_REQUIRE_LOGIN=true

# Plex (optional)
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_plex_token_here
